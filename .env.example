# ============================================================
# Emissor NFS-e Goiânia (SGISS / ABRASF 2.04 / ISSNet)
# Copie este arquivo para .env e preencha com os seus dados
# ============================================================

# --- Certificado digital A1 (e-CNPJ, arquivo .pfx/.p12) ---
# O CNPJ do certificado deve ser IDÊNTICO ao CNPJ do cadastro na Prefeitura
CERT_PATH=/caminho/para/certificado.pfx
CERT_PASS=senha_do_certificado

# --- Dados do prestador (sua empresa) ---
PRESTADOR_CNPJ=00000000000000
PRESTADOR_IM=0000000
# 1 = optante do Simples Nacional | 2 = não optante
OPTANTE_SIMPLES=1
# 1 = possui incentivo fiscal | 2 = não possui
INCENTIVO_FISCAL=2
# Regime especial de tributação (vazio = nenhum). Ex.: 6 = ME/EPP Simples Nacional
REGIME_ESPECIAL=

# --- Parâmetros do município (FAQ oficial SGISS Goiânia) ---
CODIGO_MUNICIPIO=5208707
SERIE_RPS=1
# Tipo de RPS: 1 = RPS
TIPO_RPS=1

# --- WebService (produção — não há ambiente de homologação) ---
WS_URL=https://nfse.issnetonline.com.br/abrasf204/goiania/nfse.asmx
WS_TIMEOUT=60
# Enviar certificado como TLS de cliente (normalmente NÃO é exigido pelo ISSNet;
# a autenticação é pela assinatura digital do XML). Deixe 0 salvo instrução contrária.
WS_CLIENT_CERT=0

# --- Armazenamento local ---
DB_PATH=storage/nfse.sqlite
XML_DIR=storage/xml

# --- API HTTP local (public/api.php) ---
# Token exigido no header Authorization: Bearer <token>
API_TOKEN=troque-este-token

# NF-e de produto
NFE_AMBIENTE=2
NFE_SERIE=1

# Dados do emitente para NF-e (além de PRESTADOR_CNPJ já existente)
PRESTADOR_RAZAO_SOCIAL=Lumina Energia Solar LTDA
PRESTADOR_IE=1234567890123
PRESTADOR_LOGRADOURO=Rua das Palmeiras
PRESTADOR_NUMERO=100
PRESTADOR_BAIRRO=Setor Bueno
PRESTADOR_CODIGO_MUNICIPIO=5208707
PRESTADOR_MUNICIPIO=Goiânia
PRESTADOR_UF=GO
PRESTADOR_CEP=74210015
# Logo da empresa no DANFE (opcional; PNG ou JPG). Deixe vazio para gerar sem logo.
LOGO_PATH=
